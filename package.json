{
  "name": "si-toolkit",
  "version": "1.1.0",
  "main": "main.js",
  "scripts": {
    "start": "cross-env TEST_MODE=false electron .",
    "test-rookie": "cross-env TEST_MODE=true electron .",
    "dist": "electron-builder --win portable"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^42.5.2",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "lucide-static": "^1.23.0"
  },
  "build": {
    "appId": "com.si.toolkit",
    "productName": "SI Investigation Portal",
    "win": {
      "target": "portable",
      "requestedExecutionLevel": "asInvoker",
      "icon": "images/icon.ico"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ]
  }
}
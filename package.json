{
  "name": "si-toolkit",
  "version": "1.4.0",
  "description": "SI Investigation Portal with Advanced Modular Workspace UI",
  "main": "main.js",
  "scripts": {
    "test-rookie": "cross-env TEST_MODE=true electron .",
    "start": "electron .",
    "package": "electron-builder"
  },
  "build": {
    "appId": "com.baizhi.sitoolkit",
    "productName": "SI-Investigation-Portal",
    "directories": {
      "output": "build-dist"
    },
    "win": {
      "icon": "images/icon.ico",
      "target": ["portable"],
      "requestedExecutionLevel": "asInvoker"
    },
    "files": [
      "index.html",
      "renderer.js",
      "main.js",
      "src/**/*",
      "node_modules/**/*"
    ]
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  }
}